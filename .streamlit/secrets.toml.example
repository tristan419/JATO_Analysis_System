# Streamlit Secrets 示例（不要提交真实密钥）

# 对象存储（可选）
OBJECT_STORAGE_ENDPOINT = "https://example-endpoint"
OBJECT_STORAGE_BUCKET = "jato-datasets"
OBJECT_STORAGE_ACCESS_KEY = "<your-access-key>"
OBJECT_STORAGE_SECRET_KEY = "<your-secret-key>"

# 数据读取开关（可选）
USE_OBJECT_STORAGE = false

# 预留：外部监控或日志（可选）
LOG_LEVEL = "INFO"
